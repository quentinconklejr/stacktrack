# Supabase project URL — found in Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co

# anon/public key — safe for client use, respects RLS
SUPABASE_KEY=your-anon-key-here

# service_role key — bypasses RLS, needed for cross-user community aggregation
# Get it from Project Settings > API > service_role (keep this secret!)
SUPABASE_SERVICE_KEY=your-service-role-key-here
